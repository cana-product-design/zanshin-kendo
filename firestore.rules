rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global Helper Functions
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { 
      return request.resource.data; 
    }
    
    function existing() { 
      return resource.data; 
    }
    
    function isSignedIn() { 
      return request.auth != null; 
    }

    // Entity-specific validation: User
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 && data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 256
        && data.name is string && data.name.size() <= 256
        && data.progress is map
        && (!('profile' in data) || data.profile is map)
        && (!('activePlan' in data) || data.activePlan is map || data.activePlan == null)
        && (!('plans' in data) || data.plans is list)
        && data.keys().hasAll(['uid', 'email', 'name', 'progress']);
    }

    // 3. Fortress rules for Users collection
    match /users/{userId} {
      // Direct get access only. No listing (allow list is explicitly denied to prevent scraping)
      allow get: if isSignedIn() && request.auth.uid == userId;
      
      // Creating a user record
      allow create: if isSignedIn() 
        && request.auth.uid == userId 
        && isValidId(userId)
        && isValidUser(incoming()) 
        && incoming().createdAt == request.time;
        
      // Updating user record
      allow update: if isSignedIn() 
        && request.auth.uid == userId 
        && isValidId(userId)
        && isValidUser(incoming()) 
        && incoming().updatedAt == request.time
        && incoming().uid == existing().uid
        && incoming().createdAt == existing().createdAt;

      // Disallow user deletion to preserve core logs and integrity
      allow delete: if false;
    }
  }
}
